          }
        },
        {
          "dataset": "airflow",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cffphemq3aqkgb"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  $__timeGroupAlias(\"timestamp\", 1h),\r\n  ROUND(\r\n    (\r\n      -- Драгметаллы с подстановкой последних известных значений\r\n      COALESCE(\r\n        AVG(CASE WHEN ticker = 'PALLADIUM' THEN price END),\r\n        (SELECT price FROM nornickel.market_data \r\n         WHERE ticker = 'PALLADIUM' AND timestamp <= $__timeTo() \r\n         ORDER BY timestamp DESC LIMIT 1)\r\n      ) / 31.1 * 1000 * 0.40 +\r\n      \r\n      COALESCE(\r\n        AVG(CASE WHEN ticker = 'PLATINUM' THEN price END),\r\n        (SELECT price FROM nornickel.market_data \r\n         WHERE ticker = 'PLATINUM' AND timestamp <= $__timeTo() \r\n         ORDER BY timestamp DESC LIMIT 1)\r\n      ) / 31.1 * 1000 * 0.10 +\r\n      \r\n      COALESCE(\r\n        AVG(CASE WHEN ticker = 'NICKEL' THEN price END),\r\n        (SELECT price FROM nornickel.market_data \r\n         WHERE ticker = 'NICKEL' AND timestamp <= $__timeTo() \r\n         ORDER BY timestamp DESC LIMIT 1)\r\n      ) / 1000 * 0.25 +\r\n      \r\n      COALESCE(\r\n        AVG(CASE WHEN ticker = 'COPPER' THEN price END),\r\n        (SELECT price FROM nornickel.market_data \r\n         WHERE ticker = 'COPPER' AND timestamp <= $__timeTo() \r\n         ORDER BY timestamp DESC LIMIT 1)\r\n      ) / 1000 * 0.20\r\n    ) * \r\n    COALESCE(\r\n      AVG(CASE WHEN ticker = 'USDRUB' THEN price END),\r\n      (SELECT price FROM nornickel.market_data \r\n       WHERE ticker = 'USDRUB' AND timestamp <= $__timeTo() \r\n       ORDER BY timestamp DESC LIMIT 1)\r\n    ) / 14000, \r\n  2) AS \"Корзина (Модель)\"\r\nFROM nornickel.market_data\r\nWHERE ticker IN ('PALLADIUM', 'PLATINUM', 'NICKEL', 'COPPER', 'USDRUB') \r\n  AND $__timeFilter(\"timestamp\")\r\nGROUP BY 1\r\nORDER BY 1",
          "refId": "B",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
