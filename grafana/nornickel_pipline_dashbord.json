          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH stats AS (\r\n  SELECT \r\n    AVG(spread) as mean_spread,\r\n    STDDEV(spread) as std_spread\r\n  FROM (\r\n    SELECT ((basket_price / real_price) - 1) * 100 as spread\r\n    FROM nornickel.v_global_basket\r\n    WHERE msk_time > NOW() - INTERVAL '30 days'\r\n  ) s\r\n),\r\ncurrent AS (\r\n  SELECT \r\n    ((basket_price / real_price) - 1) * 100 as spread,\r\n    msk_time\r\n  FROM nornickel.v_global_basket\r\n  ORDER BY msk_time DESC\r\n  LIMIT 1\r\n)\r\nSELECT \r\n  CASE \r\n    WHEN (spread - mean_spread) / std_spread > 2 THEN '🔥 СИЛЬНАЯ НЕДООЦЕНКА'\r\n    WHEN (spread - mean_spread) / std_spread > 1 THEN '⚠️ Умеренная недооценка'\r\n    WHEN (spread - mean_spread) / std_spread < -2 THEN '❄️ СИЛЬНАЯ ПЕРЕОЦЕНКА'\r\n    WHEN (spread - mean_spread) / std_spread < -1 THEN '⚠️ Умеренная переоценка'\r\n    ELSE '⚖️ Нейтрально'\r\n  END as text,\r\n  ROUND((spread - mean_spread) / std_spread, 2) as z_score\r\nFROM current, stats;",
