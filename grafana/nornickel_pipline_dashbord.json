        {
          "dataset": "airflow",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH stats AS (\r\n  SELECT \r\n    AVG(spread) as mean_spread,\r\n    STDDEV(spread) as std_spread\r\n  FROM (\r\n    SELECT ((basket_price / real_price) - 1) * 100 as spread\r\n    FROM nornickel.v_global_basket\r\n    WHERE msk_time > (NOW() AT TIME ZONE 'Europe/Moscow') - INTERVAL '30 days'\r\n  ) s\r\n)\r\nSELECT\r\n  msk_time as time,\r\n  ((basket_price / real_price) - 1) * 100 as spread,\r\n  (((basket_price / real_price) - 1) * 100 - mean_spread) / std_spread as z_score,\r\n  2 as \"upper_2sigma\",\r\n  1 as \"upper_1sigma\", \r\n  -1 as \"lower_1sigma\",\r\n  -2 as \"lower_2sigma\"\r\nFROM nornickel.v_global_basket, stats\r\nWHERE msk_time > NOW() - INTERVAL '30 days'\r\nORDER BY 1;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
