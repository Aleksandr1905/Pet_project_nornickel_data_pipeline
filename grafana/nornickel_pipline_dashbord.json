          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  $__timeGroupAlias(\"timestamp\", 1h),\r\n  AVG(price) AS \"ГМК (Рынок)\"\r\nFROM nornickel.market_data\r\nWHERE ticker = 'GMKN' \r\n  AND $__timeFilter(\"timestamp\")\r\nGROUP BY 1\r\nORDER BY 1",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
